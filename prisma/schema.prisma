generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Appointment {
  id               String   @id @default(cuid())
  service          String
  amount           Int
  name             String
  phone            String
  email            String
  message          String?
  status           String   @default("PENDING")
  stripeSessionId  String?  // ✅ ADD THIS
  createdAt        DateTime @default(now())
}

model Category {
  id        String    @id @default(cuid())
  name      String
  image     String    // Category thumbnail
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id           String   @id @default(cuid())
  name         String
  brand        String   @default("SkinCeuticals") // Add this line
  price        Float
  size         String
  shortDesc    String   @db.Text
  description  String   @db.Text
  howToUse     String   @db.Text
  ingredients  String   @db.Text
  aboutBrand   String   @db.Text
  skinTypes    String[] 
  image        String   
  stock        Int      @default(10)
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id])
  createdAt    DateTime @default(now())
}

model Order {
  id              String   @id @default(cuid())
  amount          Float
  status          String   @default("PENDING") // PENDING, PAID, SHIPPED
  customerEmail   String
  customerDetails Json     // Shipping address, name, phone
  items           Json     // Array of {productId, quantity, price}
  stripeSessionId String?  @unique
  createdAt       DateTime @default(now())
}